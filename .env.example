# ==================================================
# SmartCheckout — Exemplo de variáveis de ambiente
# Copie para `.env.local` e preencha com suas credenciais.
# NUNCA commite suas credenciais reais.
# ==================================================

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY
# NÃO colocar a chave `SERVICE_ROLE` aqui

# SMTP (exemplo)
SMTP_USER=your-email@example.com
SMTP_APP_PASSWORD=replace_with_app_password
SMTP_FROM_NAME=SmartCheckout

# PAGAMENTOS
PAYMENT_SIMULATION_ENABLED=true
PAYMENT_PROVIDER=asaas
GATEWAY_API_KEY=replace_with_gateway_api_key

# Outros
NEXT_PUBLIC_APP_URL=http://localhost:3000
